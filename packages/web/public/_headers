# Service worker and manifest should not be cached aggressively so updates
# propagate on every reload.

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/manifest.json
  Cache-Control: no-cache

# Icons cached for 1 day. Names are NOT content-hashed (icon-192.png is fixed),
# so a logo change + deploy takes up to 24h to propagate to existing clients.
# Reduce if faster rollout is needed.
/icons/*
  Cache-Control: public, max-age=86400
