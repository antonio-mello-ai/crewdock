# ========================================
# CrewDock Configuration
# ========================================
# Copy this file to .env and edit the values marked with "changeme".
#
# Quick setup:
#   cp .env.example .env
#   sed -i "s/changeme_password/$(openssl rand -hex 24)/" .env
#   sed -i "s/changeme_token/$(openssl rand -hex 32)/" .env
#   docker compose up -d
#   docker compose exec backend alembic upgrade head

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_platform
DB_USER=aiplatform
# Generate with: openssl rand -hex 24
DB_PASSWORD=changeme_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Authentication ---
AUTH_MODE=local
# Generate with: openssl rand -hex 32
LOCAL_AUTH_TOKEN=changeme_token

# --- CORS ---
# Comma-separated origins. Add your domain when deploying behind a proxy.
CORS_ORIGINS=http://localhost:3001

# --- Gateway (Agent Runtime) ---
# URL of agent gateway (e.g. OpenClaw). Leave default if not using one.
GATEWAY_URL=ws://localhost:18789
GATEWAY_AUTH_TOKEN=

# --- Knowledge Base ---
# URL of the QMD REST wrapper. Leave empty to disable knowledge search.
QMD_BASE_URL=

# --- Frontend ---
# API URL as seen by the browser. Empty = same origin (behind proxy).
NEXT_PUBLIC_API_URL=
# MUST match LOCAL_AUTH_TOKEN above.
NEXT_PUBLIC_API_TOKEN=changeme_token
# Display name shown in sidebar and page titles.
NEXT_PUBLIC_APP_NAME=CrewDock

# --- Cost Tracking (USD per 1M tokens) ---
ANTHROPIC_PRICING_OPUS_INPUT=15.0
ANTHROPIC_PRICING_OPUS_OUTPUT=75.0
ANTHROPIC_PRICING_SONNET_INPUT=3.0
ANTHROPIC_PRICING_SONNET_OUTPUT=15.0
