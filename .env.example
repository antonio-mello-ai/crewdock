# ========================================
# Relaix Configuration
# ========================================
# Copy this file to .env and edit the values.
# At minimum, set DB_PASSWORD and LOCAL_AUTH_TOKEN.

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_platform
DB_USER=aiplatform
DB_PASSWORD=changeme_use_strong_password    # Generate: openssl rand -hex 24

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Authentication ---
AUTH_MODE=local
LOCAL_AUTH_TOKEN=changeme_min_50_chars      # Generate: openssl rand -hex 32

# --- CORS ---
# Comma-separated origins allowed to call the API.
# Add your domain here if deploying behind a reverse proxy.
CORS_ORIGINS=http://localhost:3001

# --- Gateway (Agent Runtime) ---
# URL of the agent gateway (e.g. OpenClaw). Leave default if not using one yet.
GATEWAY_URL=ws://localhost:18789
GATEWAY_AUTH_TOKEN=

# --- Knowledge Base (QMD) ---
# URL of the QMD REST wrapper. Leave empty to disable knowledge search.
QMD_BASE_URL=

# --- Frontend ---
# API URL as seen by the browser. Empty = same origin (recommended behind proxy).
NEXT_PUBLIC_API_URL=
# Auth token for frontend API calls. Set to same value as LOCAL_AUTH_TOKEN.
NEXT_PUBLIC_API_TOKEN=
# App display name.
NEXT_PUBLIC_APP_NAME=Relaix

# --- Cost Tracking (USD per 1M tokens) ---
ANTHROPIC_PRICING_OPUS_INPUT=15.0
ANTHROPIC_PRICING_OPUS_OUTPUT=75.0
ANTHROPIC_PRICING_SONNET_INPUT=3.0
ANTHROPIC_PRICING_SONNET_OUTPUT=15.0
