# ======================
# AI Agent Platform Config
# ======================

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_platform
DB_USER=aiplatform
DB_PASSWORD=changeme_use_strong_password

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
AUTH_MODE=local
LOCAL_AUTH_TOKEN=changeme_generate_with_openssl_rand_hex_32

# Gateway (OpenClaw)
GATEWAY_URL=ws://localhost:18789
GATEWAY_AUTH_TOKEN=changeme_openclaw_gateway_token

# QMD (via Tailscale to home server)
QMD_BASE_URL=http://nextcloud:8787

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
LOG_LEVEL=info

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,https://ai.felhen.ai

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_API_TOKEN=same_as_LOCAL_AUTH_TOKEN
NEXT_PUBLIC_APP_NAME=Relaix

# Cost tracking (USD per 1M tokens)
ANTHROPIC_PRICING_OPUS_INPUT=15.0
ANTHROPIC_PRICING_OPUS_OUTPUT=75.0
ANTHROPIC_PRICING_SONNET_INPUT=3.0
ANTHROPIC_PRICING_SONNET_OUTPUT=15.0
